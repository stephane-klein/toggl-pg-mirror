    "postgres-shift": "^0.1.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@sveltejs/adapter-node": "^5.5.7",
    "@sveltejs/kit": "^2.68.0",
    "npm-package-json-lint": "^10.4.0",
    "svelte": "^5.56.4",
    "vite": "^8.1.1"
  }
