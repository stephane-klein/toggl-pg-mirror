  "author": "Stéphane Klein",
  "bin": {
    "toggl-pg-mirror": "src/cli.js"
  },
  "type": "module",
  "scripts": {
    "check": "biome check --write",
    "format": "biome format --write",
    "lint": "biome lint",
    "lint:pkg": "pnpm npmPkgJsonLint .",
    "migrate": "node src/migrate.js",
    "seed": "node src/seed.js",
