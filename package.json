{
  "name": "toggl-pg-mirror",
  "license": "MIT",
  "author": "Stéphane Klein",
  "bin": {
    "toggl-pg-mirror": "src/cli.js"
  },
  "type": "module",
  "scripts": {
    "check": "biome check --write",
    "format": "biome format --write",
    "lint": "biome lint",
    "lint:pkg": "pnpm npmPkgJsonLint .",

    "migrate": "node src/migrate.js",
    "seed": "node src/seed.js",

    "cli": "node src/cli.js",

    "postinstall": "mkdir -p node_modules/.bin && ln -sf ../../src/cli.js node_modules/.bin/toggl-pg-mirror"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "postgres-shift": "^0.1.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "npm-package-json-lint": "^10.4.0"
  }
}
